# Backend environment variables
PORT=8080

# MongoDB connection string
# Local example:
# MONGODB_URI=mongodb://127.0.0.1:27017/ecommerce
# Atlas example:
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/ecommerce

# CORS
# Comma-separated list of allowed origins (scheme + host + optional port).
# Leave unset to allow all.
# Local example:
# CORS_ORIGIN=http://localhost:5176
# EC2 example (frontend on another instance public IP):
# CORS_ORIGIN=http://<FRONTEND_PUBLIC_IP>
# EC2 example (frontend on port 80 via reverse proxy):
# CORS_ORIGIN=http://<FRONTEND_PUBLIC_IP>
# EC2 example (frontend on Vite port):
# CORS_ORIGIN=http://<FRONTEND_PUBLIC_IP>:5176
CORS_ORIGIN=http://localhost:5176
