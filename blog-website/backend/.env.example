# Backend
PORT=8080

# CORS
# Comma-separated list or single origin (scheme + host + optional port).
# Local example:
# CORS_ORIGIN=http://localhost:5173
# EC2 example (frontend hosted on another EC2 public IP):
# CORS_ORIGIN=http://<FRONTEND_PUBLIC_IP>
# EC2 example (frontend on a custom port):
# CORS_ORIGIN=http://<FRONTEND_PUBLIC_IP>:5173
# Allow both local and EC2:
# CORS_ORIGIN=http://localhost:5173,http://<FRONTEND_PUBLIC_IP>
CORS_ORIGIN=http://localhost:5173

# MongoDB
# Example (Atlas): mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
# Example (local): mongodb://127.0.0.1:27017/blog
MONGODB_URI=
