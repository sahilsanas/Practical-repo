# MongoDB Atlas (recommended) or local MongoDB
# Example Atlas: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/task_app?retryWrites=true&w=majority
MONGODB_URI=

# Backend port
PORT=8083

# Comma-separated allowed origins for CORS (or leave empty to allow all in dev)
# Example: http://localhost:5174
CORS_ORIGIN=http://localhost:5174
