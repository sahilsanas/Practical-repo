# Frontend environment variables
# If unset, frontend defaults to http://localhost:8081/api

# Local dev example:
# VITE_API_BASE_URL=http://localhost:8081/api

# EC2 example (backend hosted on another EC2 public IP and port):
# VITE_API_BASE_URL=http://<BACKEND_PUBLIC_IP>:8081/api

# If you run the backend behind a reverse proxy on port 80:
# VITE_API_BASE_URL=http://<BACKEND_PUBLIC_IP>/api

VITE_API_BASE_URL=http://localhost:8081/api
