# Backend environment variables
PORT=8081

# MongoDB connection string
# Local example:
# MONGODB_URI=mongodb://127.0.0.1:27017/student_platform
# Atlas example:
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/student_platform

# CORS
# Comma-separated list of allowed origins (scheme + host + optional port).
# Leave unset to allow all.
# Local dev example:
# CORS_ORIGIN=http://localhost:5173
# EC2 example (frontend hosted on another EC2 public IP):
# CORS_ORIGIN=http://<FRONTEND_PUBLIC_IP>
# EC2 example (frontend on a custom port):
# CORS_ORIGIN=http://<FRONTEND_PUBLIC_IP>:5173
# Allow both local and EC2:
# CORS_ORIGIN=http://localhost:5173,http://<FRONTEND_PUBLIC_IP>
CORS_ORIGIN=http://localhost:5173
